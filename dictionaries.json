  {
    "name": "07 - ONNX tiếng Việt - đọc mượt hơn",
    "rules": [
      {
        "pattern": "(^|[.!?…]\\s+)(?=(?:ngh|gh|qu)[a-zà-ỹ])",
        "replacement": "$1ờ ",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "[“”„‟«»]",
        "replacement": "\"",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "[‘’‚‛]",
        "replacement": "'",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "[…]+",
        "replacement": ".",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "[—–―]+",
        "replacement": ", ",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "[;；]+",
        "replacement": ", ",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "[:：]+",
        "replacement": ", ",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "[!！]{2,}",
        "replacement": "!",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "[?？]{2,}",
        "replacement": "?",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "([,.!?])\\s*\\1+",
        "replacement": "$1",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "\\s+([,.!?])",
        "replacement": "$1",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "([,.!?])(?=\\S)",
        "replacement": "$1 ",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "&",
        "replacement": " và ",
        "isIgnoreCase": true,
        "matchMode": "EXACT"
      },
      {
        "pattern": "\\+",
        "replacement": " cộng ",
        "isIgnoreCase": true,
        "matchMode": "REGEX"
      },
      {
        "pattern": "=",
        "replacement": " bằng ",
        "isIgnoreCase": true,
        "matchMode": "EXACT"
      },
      {
        "pattern": "%",
